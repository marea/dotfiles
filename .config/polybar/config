# Start flavours
[colors]
base00 = ee1b282d
base01 = 40484b
base02 = 656868
base03 = 8a8986
base04 = aea9a3
base05 = d3c9c0
base06 = d9d1ca
base07 = e0d9d3
base08 = 8b7b7b
base09 = 6c7a87
base0A = 707982
base0B = 627d83
base0C = 687c7d
base0D = 677c7c
base0E = 6a7b86
base0F = 8c837b
# End flavours

[bar/default]
background = ${colors.base00}
foreground = ${colors.base07}
line-size = 2

bottom = true
fixed-center = true
font-0 = GoMono Nerd Font Mono:pixelsize=20:antialias=true:hinting=true;4
font-1 = GoMono Nerd Font:pixelsize=12:antialias=true:hinting=true;3
padding-right = 1
tray-position = right
module-margin-right = 1

modules-left = ewmh
modules-center = polywins
modules-right = updates-pacman-aurhelper xbacklight date

[module/polywins]
type = custom/script
exec = ~/.config/polybar/polywins.sh 2>/dev/null
format = <label>
label = %output%
label-padding = 1
label-font = 2
tail = true

[module/updates-pacman-aurhelper]
type = custom/script
exec = ~/.config/polybar/updates-pacman-aurhelper.sh
interval = 600


[module/ewmh]
type = internal/xworkspaces
pin-workspaces = false
enable-click = true
enable-scroll = true

icon-0 = 1;爵
icon-1 = 2;
icon-2 = 3;
icon-3 = 4;
icon-4 = 5;
icon-5 = 6;
icon-6 = 7;
icon-7 = 8;
icon-8 = 9;

label-active = %icon%
label-active-foreground = ${colors.base00}
label-active-background = ${colors.base07}
label-active-padding = 1

label-occupied = %icon%
label-occupied-padding = 1

label-urgent = %icon%
label-urgent-foreground = #000000
label-urgent-background = #bd2c40
label-urgent-underline = #9b0a20
label-urgent-padding = 1

label-empty =

[module/xwindow]
label-font = 2
type = internal/xwindow
label = %title:0:60:...%

[module/xbacklight]
type = internal/xbacklight
format = <ramp>
ramp-0 = 
ramp-1 = 
ramp-2 = 

[module/date]
label-font = 2
type = internal/date
interval = 5
date-alt = " %Y-%m-%d"
time = %H:%M
time-alt = %H:%M:%S
label = %date% %time%

[settings]
screenchange-reload = true

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
