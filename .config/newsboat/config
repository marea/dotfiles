show-keymap-hint false
browser link-handler
auto-reload yes
reload-threads 10

bind-key j down
bind-key k up
bind-key j next articlelist
bind-key k prev articlelist
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key G end
bind-key g home
bind-key l open
bind-key h quit
bind-key a toggle-article-read
bind-key n next-unread
bind-key N prev-unread
bind-key U show-urls
bind-key ^r reload-urls
bind-key t set-tag
bind-key ^t clear-tag
bind-key s sort
bind-key S rev-sort

color background          color15    default
color listnormal          color14    default
color listnormal_unread   color15    default
color listfocus           color15    color2
color listfocus_unread    color8     color2
color info                color15    color8
color article             color15    default

feedlist-format "%t %> %n %u"
articlelist-format  "%t %> %f %D"
