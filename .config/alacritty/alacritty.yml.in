font:
  normal:
    family: GoMono Nerd Font Mono
    style: Regular
  bold:
    family: GoMono Nerd Font Mono
    style: Bold
  italic:
    family: GoMono Nerd Font Mono
    style: Italic
  bold_italic:
    family: GoMono Nerd Font Mono
    style: Bold Italic
  size: 8.0

colors:
  primary:
    background: %clbg%
    foreground: %clfg%
  cursor:
    text: CellBackground
    cursor: CellForeground
  selection:
    text: CellBackground
    background: CellForeground
  normal:
    black:   %cl0%
    red:     %cl1%
    green:   %cl2%
    yellow:  %cl3%
    blue:    %cl4%
    magenta: %cl4%
    cyan:    %cl5%
    white:   %cl6%
  bright:
    black:   %cl8%
    red:     %cl9%
    green:   %cl10%
    yellow:  %cl11%
    blue:    %cl12%
    magenta: %cl13%
    cyan:    %cl14%
    white:   %cl15%

background_opacity: 0.8

bell:
  animation: EaseOut
  duration: 200
  color: %cl15%

key_bindings:
  - { key: Return,   mods: Control|Shift, action: SpawnNewInstance }
