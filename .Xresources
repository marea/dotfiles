! Start flavours
! Base16 Generated
! Scheme: Flavours

#define base00 #262626
#define base01 #474747
#define base02 #686868
#define base03 #898989
#define base04 #aaaaaa
#define base05 #cbcbcb
#define base06 #d3d3d3
#define base07 #dadada
#define base08 #976e6e
#define base09 #4e854e
#define base0A #9c6e4f
#define base0B #a162a1
#define base0C #787878
#define base0D #787878
#define base0E #787878
#define base0F #787878

*foreground:   base05
#ifdef background_opacity
*background:   [background_opacity]base00
#else
*background:   base00
#endif
*cursorColor:  base05

*color0:       base00
*color1:       base08
*color2:       base0B
*color3:       base0A
*color4:       base0D
*color5:       base0E
*color6:       base0C
*color7:       base05

*color8:       base03
*color9:       base09
*color10:      base01
*color11:      base02
*color12:      base04
*color13:      base06
*color14:      base0F
*color15:      base07
! End flavours

dwm.normbgcolor: base00
dwm.normbordercolor: base00
dwm.normfgcolor: base06
dwm.selbgcolor: base02
dwm.selbordercolor: base02
dwm.selfgcolor: base06
dwm.borderpx: 5
!dwm.snap:
dwm.showbar: 1
dwm.nmaster: 1
dwm.resizehints: 0
dwm.mfact: 0.55

dmenu.font: GoMono Nerd Font:size=12
dmenu.background: base00
dmenu.foreground: base07
dmenu.selbackground: base02
dmenu.selforeground: base00


! Sensible defaults
XTerm.vt100.locale: false
XTerm.vt100.utf8: true
XTerm.vt100.scrollTtyOutput: false
XTerm.vt100.scrollKey: true
XTerm.vt100.bellIsUrgent: true
XTerm.vt100.metaSendsEscape: true
! Styling
XTerm.vt100.faceName: Go Mono Nerd Font
XTerm.vt100.boldMode: false
XTerm.vt100.faceSize: 11
XTerm.vt100.internalBorder: 0
XTerm.borderWidth: 0
! Keybindings
XTerm.vt100.translations: #override \n\
    Ctrl Shift <Key>K: scroll-back(1, halfpage) \n\
    Ctrl Shift <Key>J: scroll-forw(1, halfpage) \n\
    Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V: insert-selection(CLIPBOARD) \n\
		Ctrl Shift <Key>N: exec-formatted("xterm -e zsh", SELECT)
