! Start flavours
! Base16 Generated
! Scheme: Flavours

#define base00 #2e2423
#define base01 #4f4543
#define base02 #706663
#define base03 #918782
#define base04 #b2a8a2
#define base05 #d4c9c1
#define base06 #dad1ca
#define base07 #e0d9d4
#define base08 #a26969
#define base09 #6a7e5c
#define base0A #7e7394
#define base0B #e3a46b
#define base0C #d34930
#define base0D #956f6e
#define base0E #a56b37
#define base0F #b79b94

*foreground:   base05
#ifdef background_opacity
*background:   [background_opacity]base00
#else
*background:   base00
#endif
*cursorColor:  base05

*color0:       base00
*color1:       base08
*color2:       base0B
*color3:       base0A
*color4:       base0D
*color5:       base0E
*color6:       base0C
*color7:       base05

*color8:       base03
*color9:       base09
*color10:      base01
*color11:      base02
*color12:      base04
*color13:      base06
*color14:      base0F
*color15:      base07
! End flavours

! Sensible defaults
XTerm.vt100.locale: false
XTerm.vt100.utf8: true
XTerm.vt100.scrollTtyOutput: false
XTerm.vt100.scrollKey: true
XTerm.vt100.bellIsUrgent: true
XTerm.vt100.metaSendsEscape: true
! Styling
XTerm.vt100.faceName: Go Mono Nerd Font
XTerm.vt100.boldMode: false
XTerm.vt100.faceSize: 11
XTerm.vt100.internalBorder: 0
XTerm.borderWidth: 0
! Keybindings
XTerm.vt100.translations: #override \n\
    Ctrl Shift <Key>K: scroll-back(1, halfpage) \n\
    Ctrl Shift <Key>J: scroll-forw(1, halfpage) \n\
    Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V: insert-selection(CLIPBOARD) \n\
		Ctrl Shift <Key>N: exec-formatted("xterm -e zsh", SELECT)
